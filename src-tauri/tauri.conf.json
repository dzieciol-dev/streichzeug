{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Streichzeug",
  "version": "0.5.1",
  "identifier": "de.streichzeug.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Streichzeug",
        "width": 800,
        "height": 600,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "icon": ["icons/icon.ico", "icons/icon.icns"],
    "category": "Productivity",
    "shortDescription": "PII-Erkennung und Pseudonymisierung in der Zwischenablage",
    "longDescription": "Erkennt personenbezogene Daten beim Kopieren und ersetzt sie durch reversible Pseudonyme, bevor sie an LLMs wie ChatGPT oder Claude gepastet werden.",
    "publisher": "Streichzeug Contributors",
    "copyright": "Copyright (c) 2026 The Streichzeug Authors",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
